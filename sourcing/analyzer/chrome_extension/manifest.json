{
  "manifest_version": 3,
  "name": "마켓 파인더",
  "version": "1.2",
  "description": "쿠팡 리뷰 수집 + 알리바바 RFQ 자동 등록",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["*://www.coupang.com/*", "*://sourcing.alibaba.com/*", "http://localhost:8090/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:8090/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.coupang.com/vp/products/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://sourcing.alibaba.com/*"],
      "js": ["alibaba.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:8090/*"]
  },
  "icons": {
    "48": "icon48.png"
  }
}
