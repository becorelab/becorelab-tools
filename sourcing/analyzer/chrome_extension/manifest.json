{
  "manifest_version": 3,
  "name": "마켓 파인더 리뷰 수집기",
  "version": "1.1",
  "description": "쿠팡 상품 리뷰를 자동 수집합니다",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["*://www.coupang.com/*", "http://localhost:8090/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:8090/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.coupang.com/vp/products/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:8090/*"]
  },
  "icons": {
    "48": "icon48.png"
  }
}
